HOST=0.0.0.0
EXECUTOR_BASE_URL=http://127.0.0.1:3000
VITE_DEMO_API_BASE_URL=http://127.0.0.1:8787
MICROSANDBOX_IMAGE_DATA_SCIENCE=hari31416/sandbox-data-science:py312-v1
ENABLE_RESTRICTED_EXEC=false
RESTRICTED_EXEC_BLOCKED_IMPORTS=subprocess,socket,multiprocessing,resource,pty
SCRATCH_ROOT=/tmp/agent-sandbox
EXECUTOR_DATABASE_URL=postgresql://deepagent:deepagent_password@localhost:5432/deepagent
MINIO_END_POINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_BUCKET=deepagent
MINIO_USE_SSL=false
MINIO_SESSION_PREFIX=executor-sessions
SESSION_TTL_SECONDS=86400
SESSION_CLEANUP_INTERVAL_SECONDS=600
MAX_UPLOAD_BYTES=20971520
MAX_FILES_PER_UPLOAD=10
