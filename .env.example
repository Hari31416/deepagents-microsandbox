# Infrastructure
POSTGRES_DB=deepagent
POSTGRES_USER=deepagent
POSTGRES_PASSWORD=deepagent_password
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_BUCKET=deepagent
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# Application wiring
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3001
EXECUTOR_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Authentication / RBAC
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_COOKIE_NAME=deepagent_access_token
AUTH_REFRESH_COOKIE_NAME=deepagent_refresh_token
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_LOCKOUT_SECONDS=900
SUPER_ADMIN_EMAIL=superadmin@deepagent.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin

POSTGRES_HOST=localhost
MINIO_ENDPOINT=localhost:9000
REDIS_HOST=localhost

# URL-encoded connection strings for applications
DATABASE_URL=postgresql+psycopg://deepagent:deepagent_password@localhost:5432/deepagent
EXECUTOR_DATABASE_URL=postgresql://deepagent:deepagent_password@localhost:5432/deepagent
REDIS_URL=redis://:redis_password@localhost:6379/0

# MinIO application credentials can initially reuse root credentials in local dev.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_SECURE=false

# Model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
